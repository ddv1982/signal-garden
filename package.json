{
  "name": "signal-garden",
  "version": "0.1.22",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "pnpm i18n:compile && tsc --noEmit && vite build",
    "e2e": "pnpm i18n:compile && playwright test",
    "preview": "vite preview",
    "typecheck": "pnpm i18n:compile && tsc --noEmit",
    "test": "pnpm i18n:compile && vitest run",
    "i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --emit-ts-declarations",
    "icons:generate": "node scripts/generate-favicons.mjs",
    "assets:dark": "node scripts/create-dark-asset-variants.mjs",
    "assets:dark-background": "node scripts/create-dark-background.mjs",
    "garden:audit:dark": "node scripts/audit-dark-garden-props.mjs",
    "lens:audit": "node scripts/audit-lens-props.mjs",
    "lens:audit:dark": "node scripts/audit-lens-props.mjs src/assets/lenses/props-dark --skip-chroma",
    "lens:clean": "node scripts/clean-lens-props.mjs",
    "pet:audit": "node scripts/audit-pet-frames.mjs",
    "pet:audit:dark": "node scripts/audit-pet-frames.mjs src/assets/companion/frames-dark --skip-matte",
    "pet:sheet": "node scripts/render-pet-frame-sheet.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "phaser": "3.90.0",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.19.0",
    "@inlang/plugin-m-function-matcher": "2.2.6",
    "@inlang/plugin-message-format": "4.4.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.10.1",
    "@types/react": "~19.0.10",
    "@types/react-dom": "19.0.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^27.3.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.4",
    "sharp": "^0.34.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.2.7",
    "vitest": "^4.1.8"
  }
}
